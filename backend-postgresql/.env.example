# Local dev: start DB with `docker compose up -d` in this folder, then copy to `.env`:
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/backend_postgresql?schema=public"

PORT=4000
NODE_ENV=development

# EC2 (deploy-backend.sh, LOAD_SSM=1): no .env in this folder — secrets from SSM → /etc/todo-backend/environment only.

