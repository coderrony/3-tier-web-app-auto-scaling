# SQLite (default for local dev — no server to install)
DATABASE_URL="file:./dev.db"
DATABASE_PROVIDER=sqlite

# PostgreSQL (Docker or local install) — switch prisma/schema.prisma provider to postgresql first
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/backend_postgresql?schema=public"

PORT=4000
NODE_ENV=development

# EC2 deploy (SSM /todo-app/* or local .env): see scripts/deploy-backend.sh

