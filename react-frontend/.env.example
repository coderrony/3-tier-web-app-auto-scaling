# Local dev only — Vite exposes only VITE_* to the browser (embedded at `npm run build`).
# On EC2, deploy-frontend.sh can load /todo-app/VITE_* from AWS Parameter Store before build.

# Empty = same-origin /api (Nginx proxies to backend). Or full URL if calling API directly.
VITE_API_URL=

VITE_ENV=development
